# SCAVENGE — Environment Variables
# Copy this to .env and fill in values

# Database
DATABASE_URL=postgresql://scavenge:password@localhost:5432/scavenge
# For local dev only: DATABASE_URL=file:./dev.db (SQLite)
PERSISTENCE_MODE=memory

# Auth
JWT_SECRET=change-me-to-a-long-random-string
SCAN_TOKEN_EXPIRY_SECONDS=120
ADMIN_PASSWORD=change-me

# Media Storage (S3-compatible)
S3_BUCKET=scavenge-media
S3_REGION=us-west-2
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=  # Leave blank for AWS; set for MinIO or other S3-compatible

# AI Judging
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
AI_PROVIDER=openai  # pluggable: openai | anthropic | mock

# Server
PORT=3001
NODE_ENV=development
SOCKET_CORS_ORIGIN=http://localhost:8081,http://localhost:5173

# Web client
VITE_API_BASE_URL=http://localhost:3001/api

# Mobile client (Expo)
EXPO_PUBLIC_API_BASE_URL=http://localhost:3001/api

# Game
GAME_TIMEZONE=America/Los_Angeles
