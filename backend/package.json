{
  "name": "@scavenge/backend",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "echo \"lint not configured yet\"",
    "test": "tsx --test tests/*.test.ts",
    "migrate": "echo \"run SQL files in backend/migrations against your database\"",
    "seed": "tsx src/scripts/seed.ts",
    "smoke:prod": "powershell -ExecutionPolicy Bypass -File scripts/smoke-prod.ps1",
    "synthetic:prod": "powershell -ExecutionPolicy Bypass -File scripts/synthetic-prod.ps1"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "pg": "^8.13.1",
    "socket.io": "^4.8.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.7",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^6.0.3",
    "supertest": "^7.1.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
